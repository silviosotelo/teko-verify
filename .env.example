# Teko Verify — variables de entorno (copiar a .env y ajustar)
# Reglas: 100% on-prem, multi-tenant, fail-closed. Nada de APIs externas.

# --- Servidor ---
PORT=4400

# --- Base de datos PostgreSQL propia y dedicada de Teko ---
DATABASE_URL=postgres://teko:teko@localhost:5432/teko

# --- Modelos del motor de caras (heredado de v9) ---
TEKO_DETECTOR_MODEL=/app/models/scrfd_10g_bnkps.onnx
TEKO_RECOGNIZER_MODEL=/app/models/recognizer.onnx

# --- Modelos ML nuevos de Teko Verify ---
# PAD / liveness pasivo: Silent-Face-Anti-Spoofing (MiniFASNet) ONNX
TEKO_PAD_MODEL=/app/models/pad_minifasnet.onnx
# Anti-anteojos: Qualcomm face_attrib_net (TFLite->ONNX)
TEKO_GLASSES_MODEL=/app/models/face_attrib_net.onnx

# --- Sidecar OCR (PaddleOCR, Python) ---
OCR_SIDECAR_URL=http://localhost:8001

# --- Sesiones de verificación ---
# TTL del link_token de captura, en minutos
TOKEN_TTL_MIN=15

# --- Umbrales de decisión (calibrables, ver spec §10/§13) ---
# Coseno mínimo para el match 1:1 selfie<->foto del documento
MATCH_THRESHOLD=0.40
# Score mínimo de liveness/PAD para "persona viva"
LIVENESS_THRESHOLD=0.70
# Máximo porcentaje de anteojos tolerado en la selfie
GLASSES_MAX=0.50
