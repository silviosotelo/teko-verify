{
  "name": "teko-verify",
  "version": "0.1.0",
  "description": "Teko Verify — KYC documental + onboarding verificado (liveness + calidad/anti-anteojos + verificación 1:1 + cédula PY). On-prem, multi-tenant. Sub-proyecto B de la plataforma Teko de identidad electrónica.",
  "type": "commonjs",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "vitest",
    "migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@zxing/library": "^0.21.3",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "helmet": "^8.2.0",
    "mrz": "^4.2.1",
    "multer": "^1.4.5-lts.1",
    "onnxruntime-node": "^1.17.0",
    "pg": "^8.11.0",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "sharp": "^0.33.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.2",
    "typescript": "^5.4.0",
    "vitest": "^2.1.8"
  }
}
